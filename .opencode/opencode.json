{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/architecture/README.md",
    "docs/compliance/dependency-policy.md",
    "docs/design/handoff.md"
  ],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "references": {
    "design": {
      "path": "design/opendesign",
      "description": "Open Design artifacts, tokens, and handoff notes for the shared VAI Code visual system."
    }
  },
  "mcp": {
    "open-design": {
      "type": "local",
      "command": ["open-design", "mcp", "--daemon-url", "http://127.0.0.1:7456"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
